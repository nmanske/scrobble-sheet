# Last.fm
LASTFM_API_KEY=replace_me
LASTFM_USERNAME=replace_me

# Google Sheets
GOOGLE_SPREADSHEET_ID=replace_me
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/google-service-account.json

# Sheet names
TARGET_SHEET_NAME=Last.fm Automation
# Only needed for import-legacy
LEGACY_SOURCE_SHEET_NAME=

# Runtime
TIMEZONE=America/Chicago
SYNC_WINDOW_HOURS=24
HTTP_TIMEOUT_SECONDS=30
LASTFM_REQUEST_DELAY_MS=300
USER_AGENT=lastfm-sheet-sync/1.0 (+local)

# Local data
STATE_DIR=./data/state
CACHE_DIR=./data/cache

# Safety
DRY_RUN=false
